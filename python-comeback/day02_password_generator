import random
import string

letters = string.ascii_letters
nums = string.digits
puncs = '@#$%^&*_-~'

all_together = letters + nums + puncs

print("Welcome to Passwrod Generator")

while True:
    try:
        length = int(input("Please set password length: "))
        break
    except ValueError:
        print("Something went wrong, pelase set accurate value")


def password_generator(length):
    password = ''
    
    for i in range(length):
        password += random.choice(all_together)

    print(f"Here's your new password: {password}")

password_generator(length)
